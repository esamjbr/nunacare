{
  "permissions": {
    "allow": [
      "Read(*)",
      "Grep(*)",
      "Glob(*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(npm test*)",
      "Bash(npm run test*)",
      "Bash(npm run lint*)",
      "Bash(npm run build*)",
      "Bash(dotnet build*)",
      "Bash(dotnet test*)",
      "Bash(flutter analyze*)",
      "Bash(flutter test*)"
    ],
    "ask": [
      "Edit(*)",
      "Write(*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(npm install*)",
      "Bash(dotnet ef*)",
      "Bash(docker*)"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "Read(**/credentials*)",
      "Read(**/appsettings.Production.json)",
      "Read(**/application-prod.yml)",
      "Bash(rm -rf*)",
      "Bash(dropdb*)",
      "Bash(psql *DROP*)",
      "Bash(mysql *DROP*)",
      "Bash(curl *| sh*)",
      "Bash(wget *| sh*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/block-dangerous-bash.sh"
          }
        ]
      }
    ]
  }
}
